<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- Mirrors runtimeconfig.template.json settings for .NET Framework.
         Disabling caching is required for AppContextSwitchScope-based test scopes
         to work correctly, as CoreAppContextSwitches permanently caches switch values
         after the first read when caching is enabled. -->
    <AppContextSwitchOverrides value="TestSwitch.LocalAppContext.DisableCaching=true;System.Runtime.Serialization.EnableUnsafeBinaryFormatterSerialization=false" />
  </runtime>
</configuration>
